{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://riffle.app/schemas/release-device-evidence-v1.json",
  "title": "ReleaseDeviceEvidenceManifestV1",
  "type": "object",
  "additionalProperties": false,
  "required": ["schemaVersion", "candidate", "runs"],
  "properties": {
    "schemaVersion": { "const": 1 },
    "candidate": {
      "type": "object",
      "additionalProperties": false,
      "required": ["commitSha", "buildIdentity", "generatedAt"],
      "properties": {
        "commitSha": { "type": "string", "pattern": "^[0-9a-f]{40}$" },
        "buildIdentity": { "type": "string", "minLength": 1 },
        "generatedAt": { "type": "string", "format": "date-time" }
      }
    },
    "runs": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["scenarioId", "evidenceType", "result", "validator", "timestamp", "knownLimitation", "device"],
        "properties": {
          "scenarioId": { "type": "string", "pattern": "^[a-z0-9-]+$" },
          "evidenceType": { "enum": ["automated-emulator", "physical-device", "manual-device"] },
          "result": { "enum": ["pass", "fail", "blocked", "not-applicable"] },
          "validator": { "type": "string", "minLength": 1 },
          "timestamp": { "type": "string", "format": "date-time" },
          "knownLimitation": { "type": "string" },
          "failureResolution": { "type": "string" },
          "device": {
            "type": "object",
            "additionalProperties": false,
            "required": ["manufacturer", "model", "androidApi", "build", "formFactor", "windowMode", "installType"],
            "properties": {
              "manufacturer": { "type": "string", "minLength": 1 },
              "model": { "type": "string", "minLength": 1 },
              "androidApi": { "type": "integer", "minimum": 1 },
              "build": { "type": "string", "minLength": 1 },
              "formFactor": { "enum": ["phone", "tablet", "foldable", "desktop"] },
              "windowMode": { "enum": ["compact", "medium", "expanded", "split-screen", "fullscreen"] },
              "windowSizeClass": { "enum": ["compact", "medium", "expanded"] },
              "orientation": { "enum": ["portrait", "landscape"] },
              "posture": { "enum": ["cover", "flat", "book", "tabletop"] },
              "installType": { "enum": ["clean", "upgrade", "debug", "release"] }
            }
          }
        }
      }
    }
  }
}
